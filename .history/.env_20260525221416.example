# Example environment variables for local development
# Copy this to .env and fill values (DO NOT commit .env with secrets)

# Django
SECRET_KEY=changeme_replace_with_real_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=marketplace_db
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432

# External services
MERCADO_PAGO_ACCESS_TOKEN=

# Email (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Optional storage (S3/Cloudinary)
AWS_S3_BUCKET=
CLOUDINARY_URL=

# Security / production toggles
# Set these to True in production where appropriate (use HTTPS)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# HSTS settings (seconds)
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# When behind a proxy/load-balancer that sets X-Forwarded-Proto
USE_X_FORWARDED_PROTO=False

# X-Frame options
X_FRAME_OPTIONS=DENY

# Site URL
SITE_URL=http://127.0.0.1:8000
